# Copy to .env and fill in real values.

# --- Backend ---
LISTEN_ADDR=:8080

# Host port the app is published on (container always listens on 8080 internally).
# Change this if 8080 is already in use on the host.
APP_PORT=8080

# Postgres connection string. When using docker-compose, host is the service name.
DATABASE_URL=postgres://tww:tww@localhost:5432/tibia_warden?sslmode=disable

# Discord OAuth2 application credentials (https://discord.com/developers/applications).
DISCORD_CLIENT_ID=your_client_id
DISCORD_CLIENT_SECRET=your_client_secret
# Must exactly match a redirect URL registered in the Discord app.
# Dev: route through the Vite proxy (:5173) so the session cookie is same-origin.
# Prod: use your public URL, e.g. https://warden.example.com/api/auth/discord/callback
DISCORD_REDIRECT_URL=http://localhost:5173/api/auth/discord/callback

# Random secret used to sign/secure sessions (generate with: openssl rand -base64 48).
SESSION_SECRET=change_me_to_a_long_random_value

# The externally reachable base URL of the SPA (used for post-login redirects).
PUBLIC_BASE_URL=http://localhost:5173

# Comma-separated list of allowed browser origins (CORS + WebSocket).
ALLOWED_ORIGINS=http://localhost:5173

# When set, the backend serves the built SPA from this directory (production).
# Leave empty during local dev (Vite serves the frontend).
STATIC_DIR=

# Set to "true" in production behind HTTPS so session cookies are Secure.
COOKIE_SECURE=false

# --- Postgres (docker-compose) ---
POSTGRES_USER=tww
POSTGRES_PASSWORD=tww
POSTGRES_DB=tibia_warden
